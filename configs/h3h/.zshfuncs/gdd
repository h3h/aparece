# git delete (branch locally) and delete (branch on origin), but only if safely merged
function gdd() {
  local default=$(gdb)
  [[ $(gcb) == "$default" ]] && branch=$1 || branch=$(gcb)
  if [[ -z $(git branch --no-merged "$default" | grep "$branch") ]]; then
    echo "Deleting branch $branch..."
    git branch -d "$branch" && git push origin :"$branch"
  else
    echo "That branch hasn't been merged yet!"
  fi
}
